        - make -C /root/open-build-service/
        - make -C /root/open-build-service/ install
        - perl -p -i -e 's/OBS_USE_SLP="yes"/OBS_USE_SLP="no"/' /etc/sysconfig/obs-server
        - perl -p -i -e "s/^\s*OBS_WORKER_INSTANCES=.*/OBS_WORKER_INSTANCES=1/" /etc/sysconfig/obs-server
        - for i in worker apidelayed dispatcher deltastore repserver service servicedispatch srcserver signer signd;do systemctl restart obs$i ;done
        - systemctl stop slpd
        - systemctl disable slpd
        - zypper -n --no-gpg-check ref -s
        - zypper -n in perl-Devel-Cover
        - echo -en "[client]\nuser = root\npassword = opensuse\n" > /root/.my.cnf
  -
    use_module: Kanku::Handler::Reboot
  -
    use_module: Kanku::Handler::WaitForSystemd
  -
    use_module: Kanku::Handler::ExecuteCommandViaSSH
    options:
      username: root
      commands:
        - make -C  /tmp/kanku/dist test_system
        - make -C /tmp/kanku/src/backend test_unit
        - make -C /tmp/kanku/dist/t/osc test_system
